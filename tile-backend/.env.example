# Server Configuration
PORT=8090

# Logging Configuration
LOG_LEVEL=info

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Filesystem store root. Leave empty to default to
# ~/.local/share/ozx-roomeditor/templates (or ./templates if $HOME is unset).
# ORT-67 introduces a proper config file pointing at an OZX project folder.
TEMPLATES_DIR=
