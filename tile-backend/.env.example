# Runtime knobs only. The user-editable config (project root, templates
# subdir, port, auto_open_browser) lives in
# ~/.config/ozx-roomeditor/config.json — see README for details, or run the
# binary once to have a default written for you.

# Logging Configuration
LOG_LEVEL=info

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
